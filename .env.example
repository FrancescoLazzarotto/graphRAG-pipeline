# Neo4j — graphrag runtime and kg_pipeline read NEO4J_URL.
# NOTE: scripts/kg_repair3.py, kg_repair4.py and kg_repair5.py read NEO4J_URI
# instead; set both to the same value if you run those repair passes.
NEO4J_URL=bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
# Optional; the project database is documented in kg_pipeline/config.yaml.
NEO4J_DATABASE=

# HuggingFace (gated models)
HF_TOKEN=

# vLLM OpenAI-compatible endpoint (used with --vllm and by the LLM judge)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-32B-Instruct
VLLM_API_KEY=

# Optional tuning (defaults shown)
# GRAPHRAG_NEO4J_QUERY_RETRIES=3
# GRAPHRAG_NEO4J_QUERY_RETRY_BACKOFF_SEC=1.0
# GRAPHRAG_LLM_GENERATE_RETRIES=2
# GRAPHRAG_LLM_GENERATE_RETRY_BACKOFF_SEC=1.0
# GRAPHRAG_VLLM_HEALTHCHECK_TIMEOUT_SEC=5
# GRAPHRAG_OFFLOAD_DIR=/tmp/graphrag-offload
# EVAL_NORMALIZE_REMOVE_ACCENTS=1
